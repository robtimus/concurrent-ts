{
  "name": "@robtimus/concurrent",
  "version": "1.0.1",
  "description": "Utility classes commonly useful in concurrent programming",
  "homepage": "https://github.com/robtimus/concurrent-ts",
  "bugs": {
    "url": "https://github.com/robtimus/concurrent-ts/issues"
  },
  "license": "Apache-2.0",
  "author": "Rob Spoor",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robtimus/concurrent-ts.git"
  },
  "scripts": {
    "compile": "tsc",
    "lint": "eslint ./src/**",
    "format": "prettier --write \"**/*.+(json|ts|tsx)\"",
    "format:check": "prettier --check \"**/*.+(json|ts|tsx)\"",
    "build": "npm run format:check && npm run lint && npm run compile",
    "typedoc": "typedoc",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typedoc": "^0.28.17",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "js-yaml": "5.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/eslint-recommended",
      "plugin:@typescript-eslint/recommended"
    ]
  },
  "prettier": {
    "printWidth": 180
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverage": true
  }
}
